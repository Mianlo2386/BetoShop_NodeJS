{
  "version": 2,
  "builds": [
    {
      "src": "backend/src/app.js",
      "use": "@vercel/node",
      "config": {
        "nodeVersion": "18"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "backend/src/app.js"
    },
    {
      "src": "/health",
      "dest": "backend/src/app.js"
    },
    {
      "src": "/(.*)",
      "dest": "backend/src/app.js"
    }
  ]
}