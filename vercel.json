{
  "version": 2,
  "builds": [
    {
      "src": "frontend",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "https://beto-shop-node-js.vercel.app/api/$1"
    },
    {
      "src": "/((?!assets/).*)",
      "dest": "/frontend/templates/index.html"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/frontend/assets/$1"
    }
  ]
}
