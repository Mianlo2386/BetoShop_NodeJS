{
  "version": 2,
  "builds": [
    {
      "src": "frontend/templates/**/*",
      "use": "@vercel/static"
    },
    {
      "src": "frontend/assets/**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "destination": "https://betostore-backend.onrender.com/api/$1"
    },
    {
      "src": "/contact",
      "destination": "https://betostore-backend.onrender.com/contact"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/frontend/assets/$1"
    },
    {
      "src": "/((?!assets/).*)",
      "dest": "/frontend/templates/index.html"
    }
  ]
}
